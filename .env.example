# Shared app settings
NEXT_PUBLIC_APP_ENV=''
NEXT_PUBLIC_DEFAULT_NETWORK=''

# Local development and emulator-friendly defaults
# These values let the app run against local Firebase emulators without requiring real Google Cloud credentials.
FIRESTORE_EMULATOR_HOST='localhost:8080'
FIREBASE_AUTH_EMULATOR_HOST='localhost:9099'

# Feature flags for no-keys dev mode (set to 'true' to enable)
NEXT_PUBLIC_ENABLE_BLOCKCHAIN='false'
ENABLE_BLOCKCHAIN='false'
ENABLE_INDEXERS='false'
ENABLE_REDIS='false'
ENABLE_ALGOLIA='true'
ENABLE_AI='false'

# Firebase Client SDK (defaults work with local emulators)
NEXT_PUBLIC_FIREBASE_API_KEY='demo-key'
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN='localhost'
NEXT_PUBLIC_FIREBASE_PROJECT_ID='cbs-assembly'
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET='cbs-assembly.appspot.com'
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID='000000000000'
NEXT_PUBLIC_FIREBASE_APP_ID='1:000000000000:web:0000000000000000'

# Public client-side search config used in development and production.
NEXT_PUBLIC_ALGOLIA_APP_ID=''
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=''

# Production or deployment-only variables
# Keep these empty in the example file and fill them in from your actual secret store or deployment config.
ACCESS_TOKEN_PRIVATE_KEY=''
ACCESS_TOKEN_PUBLIC_KEY=''
ACCESS_TOKEN_PASSPHRASE=''

REFRESH_TOKEN_PRIVATE_KEY=''
REFRESH_TOKEN_PUBLIC_KEY=''
REFRESH_TOKEN_PASSPHRASE=''

NOTIFICATION_ENGINE_API_KEY=''
SUBSCAN_API_KEY=''
IMGBB_API_KEY=''
NEXT_PUBLIC_POLKASSEMBLY_API_KEY=''
NEXT_PUBLIC_GA_ID=''

FIREBASE_SERVICE_ACC_CONFIG=''
REDIS_URL=''
AI_SERVICE_URL=''

TOOLS_PASSPHRASE=''

IS_CACHE_ENABLED='true'
IS_AI_ENABLED='true'
IS_NOTIFICATION_SERVICE_ENABLED='true'

GOOGLE_API_KEY=''

KUSAMA_ASSETHUB_UNIFIED_SQUID_URL=''
POLKADOT_ASSETHUB_UNIFIED_SQUID_URL=''

# Set this only for production deployments or preview environments that need a stable public base URL.
NEXT_PUBLIC_SITE_URL=''

# Public app URL used by pages that need an absolute origin across different deployment platforms.
NEXT_PUBLIC_APP_URL=''

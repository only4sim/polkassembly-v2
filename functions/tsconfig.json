{
	"compilerOptions": {
		"module": "NodeNext",
		"esModuleInterop": true,
		"moduleResolution": "NodeNext",
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"outDir": "lib",
		"rootDir": "src",
		"sourceMap": true,
		"strict": true,
		"target": "es2017",
		"paths": {
			"*": ["./*"]
		},
		"skipLibCheck": true
	},
	"compileOnSave": true,
	"include": ["src"],
	"exclude": ["node_modules", "lib"]
}
